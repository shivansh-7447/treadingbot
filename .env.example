# =============================================================================
# Optional: committed defaults live in `.env.defaults` (no secrets). config.js loads
# `.env` first, then `.env.defaults`, without overriding host or `.env` values.
#
# Vercel → Project → Settings → Environment Variables
# Add each name below; use the same values locally by copying this file to .env
#
# CRITICAL — General → Root Directory: leave EMPTY (repository root).
# Do NOT set Root Directory to "dashboard". The app needs package.json, bot.js,
# config.js, and api/ at the repo root; /api/* will 404 if only dashboard/ is deployed.
#
# Vercel sets automatically: PORT, VERCEL — do not define those yourself.
#
# Recommended minimum for production:
#   SESSION_SECRET      (long random string; required for secure sessions)
#   DASHBOARD_PASSWORD  (not the default "change-me-now")
#   SQLITE_PATH=/tmp/bot.db   (serverless FS is ephemeral; use a real DB later)
#
# Safer defaults on Vercel:
#   PAPER_TRADING_ONLY=true
#   WEBSOCKET_ENABLED=false     (live /ws is not used when VERCEL is set)
# =============================================================================

# --- App ---
# PORT=3000
# PYTHON_BIN=python

# --- Storage (Vercel: use /tmp or external DB) ---
# SQLITE_PATH=/tmp/bot.db

# --- Dashboard auth (maps to config.auth) ---
# DASHBOARD_AUTH_ENABLED=true
# DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=
SESSION_SECRET=

# --- Realtime (local only meaningful for WebSocket server) ---
# WEBSOCKET_ENABLED=true
# WS_BROADCAST_INTERVAL_MS=5000

# --- Trading safety ---
# PAPER_TRADING_ONLY=true
# EXIT_ON_MARKET_INTELLIGENCE=false
# EXIT_ON_AUTO_TREND_REVERSAL=false
# EXIT_ON_AUTO_WHALE_REVERSAL=false

# --- Capital ---
# CAPITAL_INITIAL_INR=5000
# CAPITAL_EFFECTIVE_TRADE_SIZE_PCT=100
# CAPITAL_MAX_TRADES_REQUESTED_PER_DAY=100
# CAPITAL_MAX_TRADES_SAFE_PER_DAY=100
# CAPITAL_EFFECTIVE_MAX_TRADES_PER_DAY=100

# --- Capital growth (see config.js for defaults) ---
