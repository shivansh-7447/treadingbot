# Committed defaults — no secrets. Render/local: set SESSION_SECRET, DASHBOARD_PASSWORD,
# and exchange keys in the host UI or in .env (gitignored).

NODE_ENV=production

PAPER_TRADING_ONLY=true
BINANCE_SANDBOX=true
COINDCX_SANDBOX=false

WEBSOCKET_ENABLED=true
WS_BROADCAST_INTERVAL_MS=5000

DASHBOARD_AUTH_ENABLED=true
DASHBOARD_USERNAME=admin

EXIT_ON_MARKET_INTELLIGENCE=false
EXIT_ON_AUTO_TREND_REVERSAL=false
EXIT_ON_AUTO_WHALE_REVERSAL=false
